<% layout('layouts/boilerplate') %>
<div class="container">
    <div class="card mb-3">
        <h1 class="text-center card-header" style="background-color: #e9899b;">Bonus&#128055;Piglet</h1>
        <div class="card-body">
            <div class="col-8 offset-2">
                <form action="/piggybank" method="POST" novalidate class="validated-form">
                    <input type="hidden" name="piggybank[status]" value="piglet&#128055;">
                    <input type="hidden" name="piggybank[currency]" value="potatoes&#129364;">
                    <input type="hidden" name="piggybank[type]" value="bonus">
                    <div class="mb-3">
                        <label for="name" class="form-label">Piglet Name</label>
                        <input type="text" class="form-control" id="name" name="piggybank[name]" required>
                        <div class="valid-feedback"></div>
                    </div>
                    <div class="mb-3">
                        <label for="points" class="form-label">Potatoes</label>
                        <input type="number" class="form-control" id="points" name="piggybank[points]" required>
                        <div class="valid-feedback"></div>
                    </div>
                    <div class="mb-3">
                        <label for="date" class="form-label">Birthday</label>
                        <input type="date" class="form-control" id="date" name="piggybank[date]" required>
                        <div class="valid-feedback"></div>
                    </div>
                    <div class="mb-3">
                        <label for="description" class="form-label">Introduction</label>
                        <input type="text" class="form-control" id="description" name="piggybank[description]">
                        <div class="valid-feedback"></div>
                    </div>
                    <div class="mb-3">
                        <label for="image" class="form-label">Image</label>
                        <input type="text" class="form-control" id="image" name="piggybank[image]">
                        <div class="valid-feedback"></div>
                    </div>
                    <div class="mb-3">
                        <button class="btn" style="background-color: #e9899b">Add Bonus Piglet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-8 offset-2 mb-3" style="align-items: center;display: flex;justify-content: center;">
        <a class="btn" style="background-color: #e9899b;" href="/piggybank/newpiggy">Back to New Piglet</a>
    </div>
    <div class="col-8 offset-2 mb-3" style="align-items: center;display: flex;justify-content: center;">
        <a class="btn" style="background-color: #fce7d8" href="/piggybank">Back to Piggy Bank</a>
    </div>
</div>
