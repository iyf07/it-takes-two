<% layout('layouts/boilerplate')%>
<div class="container">
    <h1 class="text-center">Edit Model</h1>
    <div class="col-8 offset-2">
        <form action="/piggybank/piggymodel/<%=piggymodel._id%>?_method=PUT" method="POST">
            <div class="mb-3">
                <label for="name" class="form-label">Model Name</label>
                <input type="text" class="form-control" id="name" name="piggymodel[name]" value="<%=piggymodel.name%>">
            </div>
            <div class="mb-3">
                <label for="points" class="form-label">Potatoes</label>
                <input type="number" class="form-control" id="points" name="piggymodel[points]" value="<%=piggymodel.points%>">
            </div>
            <div class="mb-3">
                <label for="description" class="form-label">Introduction</label>
                <input type="text" class="form-control" id="description" name="piggymodel[description]" value="<%=piggymodel.description%>">
            </div>
            <div class="mb-3">
                <button class="btn btn-dark">Update Model</button>
                <p></p>
                <a class="btn btn-light btn-outline-dark" href="/piggybank/piggymodel">Back to Piggy</a>
            </div>
        </form>

    </div>
</div>