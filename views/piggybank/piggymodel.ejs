<% layout('layouts/boilerplate') %>
<div class="container">
    <h1 style="text-align:center">Piggy Model</h1>
    <div class="row">
        <div class="column">
            <a class="btn btn-dark" href="/piggybank/piggymodel/newmodel">New Model</a>
            <a class="btn btn-light btn-outline-dark" href="/piggybank/">Piggy Bank</a>
        </div>
    </div>
    <p></p>
    <% let i = 0; %>
    <div class="accordion">
        <% for (let piggymodel of piggymodels){ %>
            <div class="accordion-item">
                <h2 class="accordion-header" id="model<%=i%>>">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                            data-bs-target="#flush-collapse<%=i%>" aria-expanded="false" aria-controls="flush-collapse<%=i%>">
                        <%= piggymodel.name %> - <%= piggymodel.points %><%= piggymodel.currency.slice(-2)%>
                    </button>
                </h2>
                <div id="flush-collapse<%=i%>" class="accordion-collapse collapse" aria-labelledby="model<%=i%>>"
                     data-bs-parent="#accordionFlushExample">
                    <div class="accordion-body">
                        <div class="card-body">
                            <p><%= piggymodel.description %></p>
                        </div>
                        <li class="list-group-item">
                            <a class="card-link btn btn-dark" href="/piggybank/piggymodel/<%= piggymodel._id %>/edit">Edit</a>
                            <form class="d-inline" action="/piggybank/piggymodel/<%= piggymodel._id %>?_method=DELETE"
                                  method="POST">
                                <button class="btn btn-light btn-outline-dark">Abandon</button>
                            </form>
                        </li>
                    </div>
                </div>
            </div>
            <% i++; %>
        <% } %>
        <p></p>
    </div>
</div>