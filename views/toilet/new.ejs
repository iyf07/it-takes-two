<% layout('layouts/boilerplate') %>
<div class="container">
    <div class="card mb-3">
        <h1 class="poop text-center card-header">New&#128169;Poop</h1>
        <div class="card-body">
            <div class="col-10 offset-1">
                <form action="/toilet" method="POST" novalidate class="validated-form">
                    <input type="hidden" name="poop[status]" value="Active">
                    <div class="mb-3">
                        <label for="poop-name" class="form-label">Poop Name</label>
                        <input type="text" class="form-control" id="poop-name" name="poop[name]" required>
                        <div class="valid-feedback"></div>
                    </div>
                    <div class="mb-3">
                        <label for="poop-date" class="form-label">Date</label>
                        <input type="date" class="form-control" id="poop-date" name="poop[date]" required>
                        <div class="valid-feedback"></div>
                    </div>
                    <div class="mb-3">
                        <label for="poop-description" class="form-label">Description</label>
                        <input type="text" class="form-control" id="poop-description" name="poop[description]"
                               required>
                        <div class="valid-feedback"></div>
                    </div>
                    <div class="mb-3 d-grid gap-2">
                        <button class="btn poop"
                                id="poop-submit" <%= !user.type || user.type === "" ? "disabled" : {} %>>Add
                            poop
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="col-8 offset-2 mb-3 outcenter">
        <a class="btn poop" href="/toilet">Back to Toilet</a>
    </div>
</div>
