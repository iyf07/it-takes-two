<% layout('layouts/boilerplate') %>
<div class="container">
    <div class="card mb-3">
        <h1 class="piglet text-center card-header">New&#128061;Piglet</h1>
        <div class="card-body">
            <div class="col-10 offset-1">
                <form action="/piggy-bank" method="POST" novalidate class="validated-form">
                    <input type="hidden" name="piggyBank[status]" value="piglet&#128061;">
                    <input type="hidden" name="piggyBank[type]" value="normal">
                    <input type="hidden" name="piggyBank[priority]" value=1>
                    <div class="mb-3">
                        <label for="piggyModel" class="form-label">Piglet Model</label>
                        <div class="card mb-3">
                            <div class="card-body" id="piggyModel">
                                <% let i = 0; %>
                                <% for (let piggyModel of piggyModels){ %>
                                    <div class="form-check" <%= !user.type || user.type === "" ? "hidden" : {} %>>
                                        <input class="form-check-input" name="piggyBankId" type="radio"
                                               id="piggy-model-<%= i %>"
                                               value="<%= piggyModel._id %>" <%= i === 0 ? "checked" : {} %>>
                                        <label class="form-check-label" for="piggy-model-<%= i %>">
                                            <%= piggyModel.points %><%= piggyModel.currency.slice(-2) %><%= piggyModel.name %>
                                        </label>
                                        <% i++; %>
                                    </div>
                                <% } %>
                                <a class="btn piglet d-grid gap-2" href="/piggy-bank/new-bonus-piggy">Bonus
                                    Piglet</a>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="piggy-date" class="form-label">Birthday</label>
                        <input type="date" class="form-control" id="piggy-date" name="piggyBank[date]" required>
                        <div class="valid-feedback"></div>
                    </div>
                    <div class="mb-3">
                        <label for="piggy-description" class="form-label">Description</label>
                        <input type="text" class="form-control" id="piggy-description" name="piggyBank[description]">
                        <div class="valid-feedback"></div>
                    </div>
                    <div class="mb-3 d-grid gap-2">
                        <button class="btn piglet"
                                id="piggy-submit" <%= !user.type || user.type === "" ? "disabled" : {} %>>Add
                            Piglet
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="col-8 offset-2 mb-3 outcenter">
        <a class="btn piggy" href="/piggy-bank">Back to Piggy Bank</a>
    </div>
</div>
