<% layout('layouts/boilerplate') %>
<div class="container">
    <div class="card mb-3">
        <h1 class="text-center card-header piglet">Bonus&#128055;Piglet</h1>
        <div class="card-body">
            <div class="col-10 offset-1">
                <form action="/piggy-bank" method="POST" novalidate class="validated-form">
                    <input type="hidden" name="piggyBank[status]" value="piglet&#128055;">
                    <input type="hidden" name="piggyBank[currency]" value="potatoes&#129364;">
                    <input type="hidden" name="piggyBank[type]" value="bonus">
                    <input type="hidden" name="piggyBank[priority]" value=1>
                    <div class="mb-3">
                        <label for="bonus-name" class="form-label">Piglet Name</label>
                        <input type="text" class="form-control" id="bonus-name" name="piggyBank[name]" required>
                        <div class="valid-feedback"></div>
                    </div>
                    <div class="mb-3">
                        <label for="bonus-points" class="form-label">Potatoes</label>
                        <input type="number" class="form-control" id="bonus-points" name="piggyBank[points]" required>
                        <div class="valid-feedback"></div>
                    </div>
                    <div class="mb-3">
                        <label for="bonus-date" class="form-label">Birthday</label>
                        <input type="date" class="form-control" id="bonus-date" name="piggyBank[date]" required>
                        <div class="valid-feedback"></div>
                    </div>
                    <div class="mb-3">
                        <label for="description" class="form-label">Introduction</label>
                        <input type="text" class="form-control" id="description" name="piggyBank[description]">
                        <div class="valid-feedback"></div>
                    </div>
                    <div class="mb-3 d-grid gap-2">
                        <button class="btn piglet"
                                id="bonus-submit" <%= !user.type || user.type === "" ? "disabled" : {} %>>Add Bonus
                            Piglet
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="col-8 offset-2 mb-3 outcenter">
        <a class="btn piglet " href="/piggy-bank/new-piggy">Back to New Piglet</a>
    </div>
    <div class="col-8 offset-2 mb-3 outcenter">
        <a class="btn piggy" href="/piggy-bank">Back to Piggy Bank</a>
    </div>
</div>
