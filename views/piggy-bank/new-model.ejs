<% layout('layouts/boilerplate') %>
<div class="container">
    <div class="card mb-3">
        <h1 class="card-header text-center boar">New&#128023;Model</h1>
        <div class="card-body">
            <div class="col-10 offset-1">
                <form action="/piggy-bank/piggy-model" method="POST" novalidate class="validated-form">
                    <input type="hidden" name="piggymodel[level]" value=0>
                    <input type="hidden" name="piggymodel[exp]" value=0>
                    <div class="mb-3">
                        <label for="model-name" class="form-label">Model Name</label>
                        <input type="text" class="form-control" id="model-name" name="piggymodel[name]" required>
                        <div class="valid-feedback"></div>
                    </div>
                    <div class="mb-3">
                        <label for="model-points" class="form-label">Value</label>
                        <input type="number" class="form-control" id="model-points" name="piggymodel[points]" required>
                        <div class="valid-feedback"></div>
                    </div>
                    <div class="mb-3">
                        <label for="currency" class="form-label">Currency</label>
                        <div id="piggymodel">
                            <div class="form-check">
                                <input class="form-check-input" name="piggymodel[currency]" type="radio" id="potatoes"
                                       value="potatoes&#129364;">
                                <label class="form-check-label" for="potatoes">Potato&#129364;</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" name="piggymodel[currency]" type="radio"
                                       id="watermelons"
                                       value="watermelons&#127817;">
                                <label class="form-check-label" for="watermelons">Watermelon&#127817;</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" name="piggymodel[currency]" type="radio" id="eggs"
                                       value="eggs&#129370;">
                                <label class="form-check-label" for="eggs">Egg&#129370;</label>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="model-description" class="form-label">Introduction</label>
                        <input type="text" class="form-control" id="model-description" name="piggymodel[description]"
                               required>
                        <div class="valid-feedback"></div>
                    </div>
                    <div class="mb-3 d-grid gap-2">
                        <button class="btn boar" id="model-submit" <%= user.type === "Main" ? {} : "Disabled" %>>Add
                            Model
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="col-8 offset-2 mb-3 outcenter">
        <a class="btn boar" href="/piggy-bank/piggy-model">Back to Piggy Model</a>
    </div>
</div>